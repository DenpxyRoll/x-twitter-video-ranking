{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "x-twitter-video-ranking",
  "main": "src/worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    { "binding": "VIDEO_CLICKS", "id": "8d874645a7cb44cda3c7a61d86ae3127" }
  ]
}
